# Copy this file to .env.local and fill in your Supabase project credentials.
# Get them from https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL (used for email confirmation redirect).
# For local dev: http://localhost:3000
# For production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin bootstrap (server-only, never NEXT_PUBLIC_) ---
# Service-role key from Supabase dashboard → API. Bypasses RLS.
# Used to auto-promote ADMIN_EMAILS users to role='admin' on first login.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of emails that should be promoted to admin
# automatically on login. Lowercased for matching.
# Example: ADMIN_EMAILS=alice@example.com,bob@example.com
ADMIN_EMAILS=

# --- Stripe billing (server-only, never NEXT_PUBLIC_) ---
# Secret key from Stripe dashboard -> Developers -> API keys (use the test key
# in dev: sk_test_...).
STRIPE_SECRET_KEY=
# Signing secret for the webhook endpoint. For local dev, `stripe listen`
# prints one (whsec_...); in prod, copy it from the webhook you create.
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs (price_...) for each paid tier. Create one Product per
# tier in Stripe with both a monthly and an annual (-15%) recurring price,
# then paste the price ids here.
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=
STRIPE_PRICE_UNLIMITED=
# Annual prices for the same products (yearly interval, ~15% cheaper).
STRIPE_PRICE_PLUS_ANNUAL=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_UNLIMITED_ANNUAL=
